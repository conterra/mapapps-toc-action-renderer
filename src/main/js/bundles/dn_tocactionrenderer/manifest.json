{
    "name": "dn_tocactionrenderer",
    "version": "1.4.1-SNAPSHOT",
    "title": "${bundleName}",
    "description": "${bundleDescription}",
    "vendor": "con terra GmbH",
    "productName": "devnet-mapapps-toc-action-renderer",
    "dependencies": {
        "apprt-core": "^4.20.0",
        "apprt-binding": "^4.20.0",
        "ct": "^4.20.0",
        "apprt-vue": "^4.20.0",
        "apprt-vuetify": "^4.20.0",
        "@arcgis/core": "^4.33.0",
        "dn_vuecolor": "^2.8.1"
    },
    "cssThemesExtension": [
        {
            "name": "*",
            "files": [
                "./css/styles.css"
            ]
        }
    ],
    "layout-widgets": [
        {
            "widgetRole": "tocRendererChanger",
            "window": {
                "title": "${windowTitle}",
                "dockTool": "tocRendererChangerToggleTool",
                "marginBox": {
                    "w": 550,
                    "h": 550
                },
                "closable": true,
                "resizable": true,
                "minimizeOnClose": true
            }
        }
    ],
    "components": [
        {
            "name": "Config",
            "impl": "./TocRendererChangerModel",
            "provides": [
                "dn_tocactionrenderer.TocRendererChangerModel"
            ],
            "propertiesConstructor": true,
            "properties": {
                "selectedRenderer": "simple",
                "selectedUniqueValueSymbol": "circle",
                "allowedRenderers": [
                    "simple",
                    "symbol",
                    "class_breaks",
                    "size",
                    "unique_values",
                    "heatmap"
                ],
                "heatmapRenderer": {
                    "colorStops": [
                        {
                            "ratio": 0,
                            "color": {
                                "r": 255,
                                "g": 255,
                                "b": 255,
                                "a": 0
                            }
                        },
                        {
                            "ratio": 0.2,
                            "color": {
                                "r": 255,
                                "g": 255,
                                "b": 255,
                                "a": 1
                            }
                        },
                        {
                            "ratio": 0.5,
                            "color": {
                                "r": 255,
                                "g": 140,
                                "b": 0,
                                "a": 1
                            }
                        },
                        {
                            "ratio": 0.8,
                            "color": {
                                "r": 255,
                                "g": 140,
                                "b": 0,
                                "a": 1
                            }
                        },
                        {
                            "ratio": 1,
                            "color": {
                                "r": 255,
                                "g": 0,
                                "b": 0,
                                "a": 1
                            }
                        }
                    ]
                },
                "color": [
                    200,
                    200,
                    200,
                    1
                ],
                "outlineColor": [
                    200,
                    200,
                    200,
                    1
                ],
                "outlineWidth": 1,
                "pointSize": 6,
                "uniqueValueSize": 6,
                "symbolURL": "https://www.conterra.de/sites/default/files/images/icons/rocket.svg",
                "symbolHeight": 24,
                "symbolWidth": 24,
                "uniqueValueSymbolURL": ""
            }
        },
        {
            "name": "TocRendererChangerWidgetFactory",
            "provides": [
                "dijit.Widget",
                "dn_tocactionrenderer.TocRendererChangerWidget"
            ],
            "instanceFactory": true,
            "properties": {
                "widgetRole": "tocRendererChanger"
            },
            "references": [
                {
                    "name": "_model",
                    "providing": "dn_tocactionrenderer.TocRendererChangerModel"
                },
                {
                    "name": "_mapWidgetModel",
                    "providing": "map-widget.MapWidgetModel"
                }
            ]
        },
        {
            "name": "TocRendererChangerActionDefinitionFactory",
            "provides": [
                "toc.ActionDefinitionFactory"
            ],
            "references": [
                {
                    "name": "_model",
                    "providing": "dn_tocactionrenderer.TocRendererChangerModel"
                },
                {
                    "name": "_tool",
                    "providing": "ct.tools.Tool",
                    "filter": "(id=tocRendererChangerToggleTool)"
                }
            ]
        },
        {
            "name": "TocRendererChangerToggleTool",
            "impl": "ct/tools/Tool",
            "provides": [
                "ct.tools.Tool"
            ],
            "propertiesConstructor": true,
            "properties": {
                "id": "tocRendererChangerToggleTool",
                "title": "${tool.title}",
                "tooltip": "${tool.tooltip}",
                "iconClass": "color_lens",
                "toolRole": "toolset",
                "togglable": true,
                "activateHandler": "enableBinding",
                "deactivateHandler": "disableBinding"
            },
            "references": [
                {
                    "name": "handlerScope",
                    "providing": "dn_tocactionrenderer.TocRendererChangerWidget"
                }
            ]
        }
    ]
}
